# Option A — OpenRouter (routes to any model)
AI__LLM_API_KEY=your-api-key
AI__LLM_BASE_URL=https://openrouter.ai/api/v1
AI__LLM_MODEL=openai/gpt-4o-mini

# Option B — Direct OpenAI
# AI__LLM_API_KEY=your-openai-api-key
# AI__LLM_BASE_URL=https://api.openai.com/v1
# AI__LLM_MODEL=gpt-4o-mini

# Embeddings — defaults to same key/url as LLM if not set
# AI__EMBEDDING_API_KEY=your-openai-api-key
# AI__EMBEDDING_BASE_URL=https://api.openai.com/v1
AI__EMBEDDING_MODEL=text-embedding-3-small

# Database
DB__HOST=postgres
DB__PORT=5432
DB__USER=postgres
DB__PASSWORD=postgres
DB__NAME=postgres

# App
APP__LOG_LEVEL=INFO
APP__DEBUG=false
